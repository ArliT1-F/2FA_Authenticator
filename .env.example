# Postgres connection string
DATABASE_URL="postgresql://user:password@localhost:5432/authenticator?schema=public"

# Random long string for signing auth cookies/JWTs
AUTH_SECRET="replace-with-a-random-long-secret"

# Base64 encoded 32-byte key. Generate with:
# openssl rand -base64 32
ENCRYPTION_KEY="replace-with-base64-32-byte-key"
