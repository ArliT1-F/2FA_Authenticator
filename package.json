{
  "name": "2fa-authenticator",
  "version": "0.1.0",
  "description": "A secure, privacy-focused 2FA authenticator for personal use",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:security": "npm audit && eslint src/ --ext .js,.jsx,.ts,.tsx",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src/ --ext .js,.jsx,.ts,.tsx --fix",
    "build": "expo build",
    "build:android": "expo build:android",
    "build:ios": "expo build:ios"
  },
  "dependencies": {
    "expo": "^53.0.15",
    "expo-status-bar": "~1.6.0",
    "react": "18.2.0",
    "react-native": "0.72.6",
    "react-native-screens": "~3.22.0",
    "react-native-safe-area-context": "4.6.3",
    "@react-navigation/native": "^6.1.7",
    "@react-navigation/bottom-tabs": "^6.5.8",
    "@react-navigation/stack": "^6.3.17",
    "react-native-gesture-handler": "~2.12.0",
    "react-native-reanimated": "~3.3.0",
    "expo-camera": "~13.4.2",
    "expo-barcode-scanner": "~12.5.3",
    "expo-local-authentication": "^16.0.5",
    "expo-secure-store": "^14.2.3",
    "expo-clipboard": "~4.3.1",
    "@expo/vector-icons": "^13.0.0",
    "crypto-js": "^4.2.0",
    "jsqr": "^1.4.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.14",
    "@types/react-native": "~0.72.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.44.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-native": "^4.0.0",
    "eslint-plugin-security": "^1.7.1",
    "jest": "^29.2.1",
    "jest-expo": "~49.0.0",
    "typescript": "^5.1.3"
  },
  "keywords": [
    "2fa",
    "totp",
    "authenticator",
    "security",
    "privacy",
    "react-native",
    "mobile"
  ],
  "author": "ArliT1-F",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArliT1-F/2FA_Authenticator.git"
  },
  "bugs": {
    "url": "https://github.com/ArliT1-F/2FA_Authenticator/issues"
  },
  "homepage": "https://github.com/ArliT1-F/2FA_Authenticator#readme",
  "private": false,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}